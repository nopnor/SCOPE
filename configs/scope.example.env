SCOPE_CONTROLLER=outer_agent
SCOPE_CONTROLLER_AGENT=codex

# Image generation backend.
SCOPE_IMAGE_PROVIDER=jdcloud_gemini
SCOPE_IMAGE_API_KEY=
SCOPE_IMAGE_BASE_URL=https://modelservice.jdcloud.com/v1
SCOPE_IMAGE_MODEL=Gemini 3-Pro-Image-Preview
SCOPE_IMAGE_EDIT_MODEL=Gemini 3-Pro-Image-Preview

# Optional judge backend. Normal Codex runs can also use verification.input.json.
SCOPE_JUDGE_PROVIDER=jdcloud_gemini
SCOPE_JUDGE_API_KEY=
SCOPE_JUDGE_BASE_URL=https://modelservice.jdcloud.com/v1
SCOPE_JUDGE_MODEL=Gemini 3-Pro-Preview
SCOPE_JUDGE_TIMEOUT=180

# Optional web search backend for scope-retriever.
SCOPE_SEARCH_PROVIDER=serper
SCOPE_SERPER_API_KEY=
SCOPE_SEARCH_NUM_RESULTS=5
SCOPE_SEARCH_TIMEOUT=20
